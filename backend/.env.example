# backend/.env.example
# Copy this file to .env and fill in real, secure values.

# PostgreSQL connection string (Neon):
DATABASE_URL="postgresql://neondb_owner:yourpassword@ep-holy-firefly-a12cinx4-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# JWT secret key (use a long random string)
JWT_SECRET="your-very-strong-secret-key"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional email configuration (set if backend mail functionality is used)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@example.com"
EMAIL_PASSWORD="your-email-password"

# CORS origins (frontend URLs in prod)
CORS_ORIGINS="https://fast-food-restaurant.vercel.app,https://your-frontend-domain.com"

# App environment
APP_ENV="production"
